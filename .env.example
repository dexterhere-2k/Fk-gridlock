# GridLock environment variables (all optional)
#
# Mappls / MapmyIndia (spec 07)
# Without these, the API runs in no-key fallback mode using the baked-in
# artifacts/map_cache/* (pre-computed distances + static corridor coords).
# Set these only if you want to refresh the cache or enable live geocoding.
# MAPPLS_REST_KEY=
# MAPPLS_CLIENT_ID=
# MAPPLS_CLIENT_SECRET=

# Groq (spec 02 Tier-2 NLP enrichment — one-time batch, NOT used at runtime)
# GROQ_API_KEY=

# Override the ledger path (default: /app/artifacts/ledger.sqlite3)
# GRIDLOCK_LEDGER_PATH=
